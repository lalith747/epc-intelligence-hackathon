# Application Settings
APP_NAME=AI Project Monitoring & Risk Engine
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=True
API_PREFIX=/api/v1

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database Settings
# Default: SQLite, single-host local mode, no Postgres required.
DATABASE_URL=sqlite+aiosqlite:///./ai_monitoring.db
# To use Postgres instead (e.g. with docker-compose up postgres):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_project_monitoring
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=False

# Redis Settings (optional locally — the app degrades gracefully if unreachable)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Celery Settings (only needed if you run the optional Celery worker/beat)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=True

# Groq RAG / compliance generation
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini Settings (active multimodal drawing/image provider)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GOOGLE_MODEL=gemini-1.5-flash
GOOGLE_TEMPERATURE=0.7
GOOGLE_MAX_TOKENS=2000

# OpenWeather procurement weather-risk integration
OPENWEATHER_API_KEY=your_openweather_api_key_here

# SMTP email notification delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=True

# Twilio SMS / WhatsApp notification delivery
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=
ALERT_RECIPIENT_PHONE=
ALERT_RECIPIENT_EMAIL=

# OpenAI Settings (optional alternate provider, unused unless you wire it back in)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Security Settings
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# File Upload Settings
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=.xlsx,.xls,.csv,.pdf,.mpp,.xml

# LangGraph Settings
LANGGRAPH_CHECKPOINT_TTL=86400
LANGGRAPH_MEMORY_TTL=604800

# Vector Database Settings
VECTOR_DIMENSION=1536
FAISS_INDEX_TYPE=IVFFlat

# Monitoring Settings
ENABLE_METRICS=True
METRICS_PORT=9090
LOG_LEVEL=INFO

# Local app mode
LOCAL_MODE=True
SEED_DEMO_DATA=True
FRONTEND_DIST_DIR=../frontend/dist
